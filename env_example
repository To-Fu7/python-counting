# Detection style: 'dot' for center point detection, 'line' for full edge line detection
DETECTION_STYLE = 'dot'

# LINE CONFIGURATION
# Define detection lines in alphabetical pairs: (A,B), (C,D), (E,F), ...
# Only define the first line of each pair (lineA, lineC, lineE, ...).
# The second line (lineB, lineD, lineF, ...) is auto-generated using LINE_OFFSET and OFFSET_AMOUNT.
# Or define both lines explicitly if you want manual positioning.

# LINE_OFFSET: Axis for auto-generating second line ('X' or 'Y')
# LINE_OFFSET_AMOUNT: Pixels to offset the auto-generated line
LINE_OFFSET = 'X'
LINE_OFFSET_AMOUNT = 5

# DOT_OFFSET: Axis for detection dot offset ('X' or 'Y')
# DOT_OFFSET_AMOUNT: Pixels to push detection dots beyond bbox edges (0 = on bbox edge)
DOT_OFFSET = 'Y'
DOT_OFFSET_AMOUNT = 0

# Gate 1 (lineB auto-generated from lineA + offset)
lineA = [(240, 200), (240, 540)]

# Gate 2 (uncomment to add; lineD auto-generated if omitted)
# lineC = [(90, 270), (80, 630)]

# MERGE_GATES: Unify all gates into one logical gate
# 'true' = crossing ANY in_line then ANY out_line counts as one event
# 'false' = each gate is isolated (default)
MERGE_GATES = 'false'

# SWAP IN/OUT DIRECTION
# 'false' = Cross OUT line first, then IN line to count IN (default)
# 'true' = Cross IN line first, then OUT line to count IN
